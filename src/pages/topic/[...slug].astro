---
import helloAudioSrc from '../../assets/WebPages/Rust/hello_word.mp3';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import FlexibleLayout from '../../components/UI/FlexibleLayout.vue';
import { buildMenuTree, findSiblings } from '../../utils/buildMenuTree';

export async function getStaticPaths() {
  const topicsInfo = await getCollection('topics');
  const menuTree = buildMenuTree(topicsInfo);

  return topicsInfo.map(topic => {
    // Pre-compute siblings per ogni topic
    const siblings = findSiblings(topicsInfo, topic.data.menu);
    return {
      params: { slug: topic.id },
      props: { topic, menuTree, siblings },
    };
  });
}

const { topic, menuTree, siblings } = Astro.props;

// --- 🌉 Asset Resolution Bridge ---
const allAssets = import.meta.glob('/src/assets/WebPages/**/*.{png,jpg,jpeg,gif,svg}', { eager: true });

function resolveAsset(legacyPath: string) {
  if (!legacyPath) return '';
  if (/\.(mp3|wav|ogg)$/i.test(legacyPath)) return legacyPath;
  
  const cleanPath = legacyPath.startsWith('/') ? legacyPath.slice(1) : legacyPath;
  const fullPath = `/src/assets/${cleanPath}`;
  
  const asset = allAssets[fullPath];
  if (asset) {
    const mod = (asset as any).default;
    return typeof mod === 'object' ? mod.src : mod;
  }
  return legacyPath;
}

// Audio resolve - use pre-imported audio files
function resolveAudio(legacyPath: string) {
  if (!legacyPath) return '';
  if (!/\.(mp3|wav|ogg)$/i.test(legacyPath)) return legacyPath;
  
  // Match by filename and return pre-imported URL
  if (legacyPath.includes('hello_word')) {
    return helloAudioSrc;
  }
  
  // For other audio files, return original path
  return legacyPath;
}

// 1. Risolviamo gli asset nel corpo del testo
let resolvedBody = topic.body;

// per i file .md -> ![alt](/WebPages/...)
resolvedBody = resolvedBody.replace(/!\[([^\]]*)\]\((\/WebPages\/[^)]+)\)/g, (match, alt, path) => {
  const resolved = resolveAsset(path);
  return `![${alt}](${resolved})`;
});

// per i file html src="..." o href="..."
resolvedBody = resolvedBody.replace(/(src|href)="(\/WebPages\/[^"]+)"/g, (match, attr, path) => {
  return `${attr}="${resolveAsset(path)}"`;
});

// 2. Risolviamo gli asset nelle immagini del carosello
const resolvedItems = (topic.data.images || []).map(img => resolveAsset(img));

// 3. Risolviamo l'audio
const resolvedAudio = topic.data.audio ? resolveAudio(topic.data.audio) : '';

const pageData = {
   type: topic.data.type,
   topic: topic.data.title,
   route: `/topic/${topic.id}`,
   code: resolvedBody,
   items: resolvedItems,
   pgn: topic.data.pgn || '',
   audio: resolvedAudio,
   siblings: siblings,
   menuPath: topic.data.menu,
};


---

<Layout title={topic.data.title}>
  <FlexibleLayout client:load initialPageData={pageData} initialMenuData={menuTree} />
</Layout>
