# Abilita mod_rewrite
RewriteEngine On
RewriteBase /

# Supporto MIME types per modelli 3D e font
AddType model/gltf-binary .glb
AddType model/gltf+json .gltf
AddType font/woff2 .woff2

# Configurazione PHP Altervista
AddHandler av-php8 .php

# Compressione GZIP
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Cache-Control per file statici
<IfModule mod_headers.c>
  # index.html: nessun cache
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  # Asset con hash (js, css): cache lungo
  <FilesMatch "\.(js|css|woff2|glb|gltf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Immagini e media: cache moderato
  <FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|ico|mp4|webm|pdf)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

# SPA routing: reindirizza verso index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.html [L,QSA]
